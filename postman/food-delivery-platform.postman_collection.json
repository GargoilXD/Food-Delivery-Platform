{
  "info": {
    "name": "Food Delivery Platform",
    "_postman_id": "food-delivery-platform-v1",
    "description": "Complete API collection for the Food Delivery Platform microservices. All requests route through the API Gateway on port 8080.\n\n**Quick start:**\n1. Run `docker compose up --build`\n2. Send **Auth / Register** – token is saved automatically\n3. Send **Customers / Create Customer** (uses `{{userId}}` saved from register)\n4. Work through Restaurants → Orders → Deliveries\n\nVariables `token`, `userId`, `customerId`, `restaurantId`, `menuItemId`, `orderId`, and `deliveryId` are captured automatically by test scripts on the relevant requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8080", "type": "string" },
    { "key": "token",        "value": "", "type": "string" },
    { "key": "userId",       "value": "", "type": "string" },
    { "key": "customerId",   "value": "", "type": "string" },
    { "key": "restaurantId", "value": "", "type": "string" },
    { "key": "menuItemId",   "value": "", "type": "string" },
    { "key": "orderId",      "value": "", "type": "string" },
    { "key": "deliveryId",   "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints. Register and Login responses automatically save `token` and `userId` collection variables.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+1-555-0100\",\n  \"deliveryAddress\": \"10 High Street\",\n  \"city\": \"London\",\n  \"role\": \"CUSTOMER\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('token', body.token);",
                  "    pm.collectionVariables.set('userId', String(body.userId));",
                  "    pm.test('Registered successfully', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('token', body.token);",
                  "    pm.collectionVariables.set('userId', String(body.userId));",
                  "    pm.test('Logged in successfully', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/profile", "host": ["{{baseUrl}}"], "path": ["auth", "profile"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Got profile', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Check User Exists",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/users/exists/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users", "exists", "{{userId}}"]
            }
          }
        },
        {
          "name": "JWKS (Public Keys)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/.well-known/jwks.json",
              "host": ["{{baseUrl}}"],
              "path": [".well-known", "jwks.json"]
            }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "description": "Customer profile management. Routes through the gateway at `/api/customers/**` → customer-microservice at `/customers/**`.",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/customers", "host": ["{{baseUrl}}"], "path": ["api", "customers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+1-555-0100\",\n  \"deliveryAddress\": \"10 High Street\",\n  \"city\": \"London\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('customerId', String(body.id));",
                  "    pm.test('Customer created', () => pm.expect(body.id).to.be.a('number'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Customer by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "{{customerId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Got customer', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Customer by User ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/customers/by-user?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "by-user"],
              "query": [{ "key": "userId", "value": "{{userId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Restaurants",
      "description": "Restaurant and menu management. Routes at `/api/restaurants/**` and `/api/menu-items/**` → restaurant-microservice.",
      "item": [
        {
          "name": "Create Restaurant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/restaurants?ownerId={{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "restaurants"],
              "query": [{ "key": "ownerId", "value": "{{customerId}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pizza Palace\",\n  \"description\": \"Authentic Neapolitan pizza\",\n  \"cuisineType\": \"Italian\",\n  \"address\": \"456 Oak Avenue\",\n  \"city\": \"London\",\n  \"phone\": \"+1-555-9999\",\n  \"estimatedDeliveryMinutes\": 30\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('restaurantId', String(body.id));",
                  "    pm.test('Restaurant created', () => pm.expect(body.id).to.be.a('number'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Restaurant by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/restaurants/{{restaurantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "restaurants", "{{restaurantId}}"]
            }
          }
        },
        {
          "name": "Search Restaurants by City",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/restaurants?city=London",
              "host": ["{{baseUrl}}"],
              "path": ["api", "restaurants"],
              "query": [
                { "key": "city", "value": "London" },
                { "key": "cuisineType", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Search Restaurants by Cuisine",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/restaurants?cuisineType=Italian",
              "host": ["{{baseUrl}}"],
              "path": ["api", "restaurants"],
              "query": [
                { "key": "city", "value": "", "disabled": true },
                { "key": "cuisineType", "value": "Italian" }
              ]
            }
          }
        },
        {
          "name": "Add Menu Item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/restaurants/{{restaurantId}}/menu-items?ownerId={{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "restaurants", "{{restaurantId}}", "menu-items"],
              "query": [{ "key": "ownerId", "value": "{{customerId}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Margherita Pizza\",\n  \"description\": \"Classic tomato sauce and mozzarella\",\n  \"price\": 12.99,\n  \"category\": \"PIZZA\",\n  \"available\": true\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('menuItemId', String(body.id));",
                  "    pm.test('Menu item created', () => pm.expect(body.id).to.be.a('number'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Menu Items for Restaurant",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/restaurants/{{restaurantId}}/menu-items",
              "host": ["{{baseUrl}}"],
              "path": ["api", "restaurants", "{{restaurantId}}", "menu-items"]
            }
          }
        },
        {
          "name": "Update Menu Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/menu-items/{{menuItemId}}?ownerId={{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menu-items", "{{menuItemId}}"],
              "query": [{ "key": "ownerId", "value": "{{customerId}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Margherita Pizza (Large)\",\n  \"description\": \"Classic tomato sauce and mozzarella – large size\",\n  \"price\": 15.99,\n  \"category\": \"PIZZA\",\n  \"available\": true\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Toggle Menu Item Availability",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/menu-items/{{menuItemId}}/toggle?ownerId={{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menu-items", "{{menuItemId}}", "toggle"],
              "query": [{ "key": "ownerId", "value": "{{customerId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "description": "Order lifecycle management. Routes at `/api/orders/**` → order-microservice. Placing an order triggers an `OrderPlacedEvent` on RabbitMQ which creates a delivery automatically.",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders?customerId={{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [{ "key": "customerId", "value": "{{customerId}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": {{restaurantId}},\n  \"items\": [\n    {\n      \"menuItemId\": {{menuItemId}},\n      \"quantity\": 2,\n      \"specialInstructions\": \"Extra cheese please\"\n    }\n  ],\n  \"deliveryAddress\": \"10 High Street, London\",\n  \"specialInstructions\": \"Ring doorbell twice\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('orderId', String(body.id));",
                  "    pm.test('Order placed', () => pm.expect(body.status).to.eql('PLACED'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}"]
            }
          }
        },
        {
          "name": "Get Orders for Customer",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders?customerId={{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [{ "key": "customerId", "value": "{{customerId}}" }]
            }
          }
        },
        {
          "name": "Get Orders for Restaurant",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/restaurants/{{restaurantId}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "restaurants", "{{restaurantId}}", "orders"]
            }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}/status?status=PREPARING",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}", "status"],
              "query": [
                {
                  "key": "status",
                  "value": "PREPARING",
                  "description": "PLACED | PREPARING | READY | OUT_FOR_DELIVERY | DELIVERED | CANCELLED"
                }
              ]
            }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}/cancel?customerId={{customerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}", "cancel"],
              "query": [{ "key": "customerId", "value": "{{customerId}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.test('Order cancelled', () => pm.expect(body.status).to.eql('CANCELLED'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Deliveries",
      "description": "Delivery tracking. Deliveries are created automatically when an order is placed (via RabbitMQ `OrderPlacedEvent`). Cancelling an order sets delivery status to FAILED. Routes at `/api/deliveries/**` → delivery-microservice.",
      "item": [
        {
          "name": "Get Delivery by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/{{deliveryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries", "{{deliveryId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('deliveryId', String(body.id));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Delivery by Order ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/by-order/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries", "by-order", "{{orderId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('deliveryId', String(body.id));",
                  "    pm.test('Delivery found', () => pm.expect(body.orderId).to.be.a('number'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Delivery Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/deliveries/{{deliveryId}}/status?status=IN_TRANSIT",
              "host": ["{{baseUrl}}"],
              "path": ["api", "deliveries", "{{deliveryId}}", "status"],
              "query": [
                {
                  "key": "status",
                  "value": "IN_TRANSIT",
                  "description": "ASSIGNED | IN_TRANSIT | DELIVERED | FAILED"
                }
              ]
            }
          }
        }
      ]
    },
    {
